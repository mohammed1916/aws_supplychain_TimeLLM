# AWS / API configuration
VITE_AWS_REGION=us-east-1
# Base URL output by the timewise-api CloudFormation stack (no trailing slash)
VITE_API_GATEWAY_URL=

# Authentication — outputs of the timewise-cognito stack.
# Leave both empty to run the dashboard in demo mode without a login gate.
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=

# Environment
VITE_ENVIRONMENT=production

# Feature flags (default to enabled; set to "false" to disable)
VITE_ENABLE_REAL_TIME_UPDATES=true
VITE_ENABLE_ADVANCED_ANALYTICS=true
VITE_ENABLE_AI_INSIGHTS=true
